---
const { title = "Dashboard" } = Astro.props;
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
    />

    <title>{title}</title>
  </head>

  <body class="bg-[#000] text-white flex">
    <!-- SIDEBAR -->
    <aside
      class="w-64 h-screen flex flex-col justify-between bg-[#252525] border-r border-white/10 p-6"
    >
      <!-- TOP -->
      <div>
        <!-- LOGO -->
        <div class="flex items-center gap-3 mb-10">
          <img src="/favicon.svg" alt="Logo" class="w-8 h-8 object-contain" />
          <h2 class="text-lg font-semibold tracking-tight">Workspace</h2>
        </div>

        <!-- NAV -->
        <nav class="space-y-2 text-sm">
          <!-- CLIENT NAV (DEFAULT VISIBLE) -->
          <div id="clientNav" class="space-y-2">
            <a
              href="/dashboard"
              class={`flex items-center gap-3 px-3 py-2 rounded-lg transition
              ${
                Astro.url.pathname.startsWith("/dashboard")
                  ? "bg-[#DF533C]/20 text-[#DF533C]"
                  : "text-gray-400 hover:text-white hover:bg-white/5"
              }`}
            >
              <i class="fa-solid fa-chart-line"></i>
              <span>Dashboard</span>
            </a>

            <a
              href="/websites"
              class={`flex items-center gap-3 px-3 py-2 rounded-lg transition
              ${
                Astro.url.pathname.startsWith("/websites")
                  ? "bg-[#DF533C]/20 text-[#DF533C]"
                  : "text-gray-400 hover:text-white hover:bg-white/5"
              }`}
            >
              <i class="fa-solid fa-globe"></i>
              <span>Websites</span>
            </a>
          </div>

          <!-- ADMIN NAV (HIDDEN BY DEFAULT) -->
          <div id="adminNav" style="display:none;">
            <a
              href="/admin"
              class={`flex items-center gap-3 px-3 py-2 rounded-lg transition
              ${
                Astro.url.pathname.startsWith("/admin")
                  ? "bg-[#DF533C]/20 text-[#DF533C]"
                  : "text-gray-400 hover:text-white hover:bg-white/5"
              }`}
            >
              <i class="fa-solid fa-users"></i>
              <span>Clients</span>
            </a>
          </div>
        </nav>
      </div>

      <!-- USER -->
      <div class="border-t border-white/10 pt-4">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-8 h-8 rounded-full bg-gray-700"></div>
          <div>
            <p id="userEmailSidebar" class="text-sm text-white"></p>
            <p id="userRole" class="text-xs text-gray-400">Client</p>
          </div>
        </div>

        <button
          id="logoutBtn"
          class="w-full flex items-center justify-center gap-2
          bg-red-500/80 hover:bg-red-500
          px-3 py-2 rounded-lg text-sm transition"
        >
          <i class="fa-solid fa-right-from-bracket"></i>
          Logout
        </button>
      </div>
    </aside>

    <!-- MAIN -->
    <main class="flex-1 w-full px-12 py-10">
      <div class="w-full">
        <div class="flex justify-between items-center mb-10">
          <h1 class="text-3xl font-semibold tracking-tight">{title}</h1>
        </div>

        <slot />
      </div>
    </main>

    <!-- TOAST -->
    <div
      id="toast"
      class="fixed bottom-6 right-6 bg-[#DF533C] text-white px-5 py-3 rounded-xl shadow-lg hidden text-sm"
    >
    </div>

    <script type="module">
      import { supabase } from "/supabase.js";

      const logoutBtn = document.getElementById("logoutBtn");
      const emailSidebar = document.getElementById("userEmailSidebar");

      const clientNav = document.getElementById("clientNav");
      const adminNav = document.getElementById("adminNav");

      const {
        data: { user },
      } = await supabase.auth.getUser();

      if (!user) window.location.href = "/login";

      // EMAIL
      if (emailSidebar) emailSidebar.textContent = user.email;

      // 🔥 DEFAULT: CLIENT VIEW (NO FLICKER)
      adminNav.style.display = "none";

      const roleText = document.getElementById("userRole");

      // GET ROLE
      const { data: profile } = await supabase
        .from("profiles")
        .select("role")
        .eq("id", user.id)
        .single();

      // SET ROLE TEXT
      if (profile?.role === "admin") {
        roleText.textContent = "Admin";

        clientNav.style.display = "none";
        adminNav.style.display = "block";
      } else {
        roleText.textContent = "Client";

        adminNav.style.display = "none";
      }

      // SWITCH IF ADMIN
      if (profile?.role === "admin") {
        clientNav.style.display = "none";
        adminNav.style.display = "block";
      }

      // LOGOUT
      logoutBtn.onclick = async () => {
        await supabase.auth.signOut();
        window.location.href = "/login";
      };
    </script>
  </body>
</html>
