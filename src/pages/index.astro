---
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BM Client Dashboard</title>

    <!-- FontAwesome -->
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
    />
  </head>

  <body class="bg-[#000] text-white overflow-hidden">
    <!-- HERO -->
    <section class="relative h-screen flex items-center justify-center px-6">
      <!-- 🔥 BACKGROUND GLOW LAYER 1 -->
      <div
        class="glow-animate w-[600px] h-[600px] bg-[#DF533C]/20 blur-[140px] rounded-full"
      >
      </div>

      <!-- 🔥 BACKGROUND GLOW LAYER 2 -->
      <div
        class="glow-animate w-[400px] h-[400px] bg-white/5 blur-[120px] rounded-full"
        style="animation-delay: 4s;"
      >
      </div>

      <!-- 🔥 NOISE TEXTURE -->
      <div
        class="pointer-events-none absolute inset-0 opacity-[0.03] bg-[url('https://grainy-gradients.vercel.app/noise.svg')]"
      >
      </div>

      <!-- CONTENT -->
      <div class="relative z-10 text-center max-w-2xl">
        <!-- LOGO -->
        <img
          src="/favicon.svg"
          class="w-14 h-14 mx-auto mb-6
          transition duration-300 hover:scale-110
          drop-shadow-[0_0_12px_rgba(223,83,60,0.4)]"
        />

        <!-- TITLE -->
        <h1 class="text-4xl md:text-5xl font-semibold tracking-tight mb-4">
          Manage Your Client Websites
        </h1>

        <!-- SUBTITLE -->
        <p class="text-lg text-gray-300 mb-2">
          A modern dashboard for monitoring and managing all your websites.
        </p>

        <!-- DESCRIPTION -->
        <p class="text-sm text-gray-500 mb-8">
          Track performance, access admin panels, and stay in control — all in
          one place.
        </p>

        <!-- BUTTONS -->
        <div
          class="flex flex-col sm:flex-row items-center justify-center gap-4"
        >
          <!-- SIGN IN -->
          <a
            href="/login"
            class="w-full sm:w-auto bg-[#DF533C] hover:opacity-90 transition px-6 py-3 rounded-lg font-medium flex items-center justify-center gap-2"
          >
            <i class="fa-solid fa-right-to-bracket"></i>
            Sign In
          </a>

          <!-- REGISTER -->
          <a
            href="/register"
            class="w-full sm:w-auto border border-white/10 hover:bg-white/5 transition px-6 py-3 rounded-lg font-medium flex items-center justify-center gap-2"
          >
            <i class="fa-solid fa-user-plus"></i>
            Register
          </a>
        </div>
      </div>
    </section>

    <!-- SCRIPT (OPTIONAL AUTO REDIRECT IF LOGGED IN) -->
    <script type="module">
      import { supabase } from "/supabase.js";

      const {
        data: { user },
      } = await supabase.auth.getUser();
      if (user) {
        window.location.href = "/dashboard";
      }
    </script>
  </body>
</html>
