---
import Layout from "../layouts/DashboardLayout.astro";
---

<Layout title="Clients">
  <!-- ADD CLIENT -->
  <div
    class="bg-[#252525] border border-white/10 p-6 rounded-2xl max-w-md mb-10"
  >
    <h2 class="text-lg font-semibold mb-4">Add Client</h2>

    <form id="addClientForm" class="space-y-3">
      <input
        id="email"
        placeholder="Client Email"
        class="w-full p-3 bg-black border border-white/10 rounded text-white"
        required
      />

      <input
        id="password"
        type="password"
        placeholder="Password"
        class="w-full p-3 bg-black border border-white/10 rounded text-white"
        required
      />

      <button id="submitBtn" class="bg-[#DF533C] px-4 py-2 rounded w-full">
        Create Client
      </button>
    </form>
  </div>

  <!-- CLIENT LIST -->
  <div>
    <h2 class="text-lg font-semibold mb-4">Clients</h2>
    <div id="clientList" class="space-y-3"></div>
  </div>

  <script type="module">
    import { supabase } from "/supabase.js";

    const list = document.getElementById("clientList");

    // ✅ TOAST
    window.showToast = (msg = "Done") => {
      const el = document.createElement("div");
      el.textContent = msg;
      el.className =
        "fixed bottom-5 right-5 bg-black text-white px-4 py-2 rounded shadow opacity-0 transition z-50";
      document.body.appendChild(el);

      setTimeout(() => (el.style.opacity = "1"), 10);

      setTimeout(() => {
        el.style.opacity = "0";
        setTimeout(() => el.remove(), 300);
      }, 2000);
    };

    // 🔒 CHECK ADMIN
    const {
      data: { user },
    } = await supabase.auth.getUser();

    if (!user) window.location.href = "/login";

    const { data: profile } = await supabase
      .from("profiles")
      .select("role")
      .eq("id", user.id)
      .single();

    if (profile?.role !== "admin") {
      window.location.href = "/dashboard";
    }

    // ➕ ADD CLIENT (FINAL FIXED)
    document.getElementById("addClientForm").onsubmit = async (e) => {
      e.preventDefault();

      const form = e.target;
      const email = document.getElementById("email").value;
      const password = document.getElementById("password").value;
      const button = document.getElementById("submitBtn");

      // 🔒 Prevent double click
      button.disabled = true;
      button.textContent = "Creating...";

      const { data, error } = await supabase.functions.invoke("create-user", {
        body: { email, password },
      });

      if (error) {
        window.showToast(error.message || "Failed to create client");
        button.disabled = false;
        button.textContent = "Create Client";
        return;
      }

      window.showToast("Client created");

      form.reset();
      button.disabled = false;
      button.textContent = "Create Client";

      loadClients();
    };

    // 📋 LOAD CLIENTS
    async function loadClients() {
      const { data, error } = await supabase
        .from("profiles")
        .select("*")
        .eq("role", "client");

      console.log("CLIENT DATA:", data);
      console.log("ERROR:", error);

      if (error) {
        console.error(error);
        return;
      }

      list.innerHTML = data
        .map(
          (client) => `
        <div class="bg-[#252525] border border-white/10 p-4 rounded-xl flex justify-between items-center">
          <span>${client.email}</span>
        </div>
      `,
        )
        .join("");

      // 🗑 DELETE (still basic — next step we upgrade this)
      document.querySelectorAll(".deleteBtn").forEach((btn) => {
        btn.onclick = async () => {
          if (!confirm("Delete this client?")) return;

          const { error } = await supabase
            .from("profiles")
            .delete()
            .eq("id", btn.dataset.id);

          if (error) {
            window.showToast("Delete failed");
            return;
          }

          window.showToast("Client deleted");
          loadClients();
        };
      });
    }

    loadClients();
  </script>
</Layout>
