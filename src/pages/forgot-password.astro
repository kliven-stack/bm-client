---
import "../styles/global.css";
---

<html lang="en">
  <body class="bg-[#000] text-white flex items-center justify-center h-screen">
    <div
      class="w-full max-w-md bg-white/5 border border-white/10 p-8 rounded-2xl"
    >
      <h2 class="text-xl mb-4 font-semibold">Reset Password</h2>

      <form id="resetForm" class="space-y-4">
        <input
          id="email"
          type="email"
          placeholder="Enter your email"
          class="w-full p-3 rounded bg-black border border-white/10 text-white"
          required
        />

        <button class="w-full bg-[#DF533C] py-3 rounded">
          Send Reset Link
        </button>
      </form>

      <p id="msg" class="text-sm mt-4 text-gray-400"></p>
    </div>

    <script type="module">
      import { supabase } from "/supabase.js";

      const form = document.getElementById("resetForm");
      const msg = document.getElementById("msg");

      form.onsubmit = async (e) => {
        e.preventDefault();

        const email = document.getElementById("email").value;

        const { error } = await supabase.auth.resetPasswordForEmail(email, {
          redirectTo: "https://bm-client-eta.vercel.app/update-password",
        });

        if (error) {
          msg.textContent = error.message;
          return;
        }

        form.innerHTML = `
  <div class="text-center success-animate">
    <div class="text-green-400 text-3xl mb-2">
      <i class="fa-solid fa-envelope-circle-check"></i>
    </div>
    <p class="text-sm text-gray-300">
      Reset link sent. Check your email.
    </p>
  </div>
`;
      };
    </script>
  </body>
</html>
