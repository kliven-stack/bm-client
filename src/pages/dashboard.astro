---
import Layout from "../layouts/DashboardLayout.astro";
---

<Layout title="Dashboard">
  <!-- STATS -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
    <div class="bg-[#252525] p-5 rounded-2xl border border-white/10">
      <p class="text-sm text-gray-400">Total Websites</p>
      <p id="totalSites" class="text-2xl font-semibold">0</p>
    </div>

    <div class="bg-[#252525] p-5 rounded-2xl border border-white/10">
      <p class="text-sm text-gray-400">Online</p>
      <p id="onlineSites" class="text-2xl text-green-400 font-semibold">0</p>
    </div>

    <div class="bg-[#252525] p-5 rounded-2xl border border-white/10">
      <p class="text-sm text-gray-400">Offline</p>
      <p id="offlineSites" class="text-2xl text-red-400 font-semibold">0</p>
    </div>
  </div>

  <!-- CHART -->
  <div class="bg-[#252525] border border-white/10 rounded-2xl p-6">
    <h2 class="mb-6 text-lg font-semibold">Website Status</h2>
    <canvas id="analyticsChart"></canvas>
  </div>

  <script type="module">
    import { supabase } from "/supabase.js";
    import Chart from "chart.js/auto";

    const totalEl = document.getElementById("totalSites");
    const onlineEl = document.getElementById("onlineSites");
    const offlineEl = document.getElementById("offlineSites");

    const ctx = document.getElementById("analyticsChart");

    const {
      data: { user },
    } = await supabase.auth.getUser();
    if (!user) window.location.href = "/login";

    // 🔥 STATUS CHECK
    async function checkStatus(url) {
      try {
        const res = await fetch(
          `https://api.allorigins.win/get?url=${encodeURIComponent(url)}`,
        );
        return res.ok;
      } catch {
        return false;
      }
    }

    let chart;

    async function loadAnalytics() {
      const { data } = await supabase
        .from("websites")
        .select("*")
        .eq("user_id", user.id);

      let online = 0;
      let offline = 0;

      for (const site of data) {
        const isOnline = await checkStatus(site.url);
        if (isOnline) online++;
        else offline++;
      }

      // UPDATE STATS
      totalEl.textContent = data.length;
      onlineEl.textContent = online;
      offlineEl.textContent = offline;

      // DESTROY OLD CHART (IMPORTANT)
      if (chart) chart.destroy();

      // CREATE CHART
      chart = new Chart(ctx, {
        type: "bar",
        data: {
          labels: ["Online", "Offline"],
          datasets: [
            {
              label: "Websites",
              data: [online, offline],
              backgroundColor: ["#22c55e", "#ef4444"],
              borderRadius: 8,
            },
          ],
        },
        options: {
          responsive: true,
          plugins: {
            legend: {
              labels: {
                color: "#fff",
              },
            },
          },
          scales: {
            x: {
              ticks: {
                color: "#aaa",
              },
              grid: {
                color: "rgba(255,255,255,0.05)",
              },
            },
            y: {
              ticks: {
                color: "#aaa",
              },
              grid: {
                color: "rgba(255,255,255,0.05)",
              },
            },
          },
        },
      });
    }

    loadAnalytics();
  </script>
</Layout>
